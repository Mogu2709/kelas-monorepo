{
  "name": "kelas-dashboard-monorepo",
  "private": true,
  "workspaces": [
    "frontend",
    "backend"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev -w frontend\" \"npm run dev -w backend\"",
    "dev:fe": "npm run dev -w frontend",
    "dev:be": "npm run dev -w backend"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}
